{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ppklau/netdraw/schemas/physical_links.schema.json",
  "title": "NetDraw physical_links.yml",
  "type": "object",
  "required": ["physical_links"],
  "additionalProperties": false,
  "properties": {
    "physical_links": {
      "type": "array",
      "items": { "$ref": "#/$defs/PhysicalLink" }
    }
  },
  "$defs": {
    "PhysicalLink": {
      "type": "object",
      "required": ["a_end", "z_end", "status"],
      "additionalProperties": false,
      "properties": {
        "a_end":        { "type": "string", "minLength": 1 },
        "z_end":        { "type": "string", "minLength": 1 },
        "a_interface":  { "type": "string" },
        "z_interface":  { "type": "string" },
        "kind":         { "type": "string", "enum": ["physical"] },
        "role":         { "type": "string" },
        "speed":        { "type": "string" },
        "source":       { "type": "string", "enum": ["manual", "lldp_discovery", "design_intent"] },
        "status":       { "$ref": "#/$defs/Status" },
        "lag_id":       { "type": "string" }
      }
    },
    "Status": {
      "type": "string",
      "enum": ["concept", "planned", "confirmed", "active"]
    }
  }
}
